{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${PLUGIN_ROOT}/hooks/automation/memdir_hook.sh\" session-start",
            "commandWindows": "cmd.exe /d /c \"\"${PLUGIN_ROOT}\\hooks\\automation\\memdir_hook.cmd\" session-start\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
