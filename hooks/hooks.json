{
  "description": "Claude Code hooks for project-memdir memory recall and extraction.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/claude/memdir-hook.mjs",
              "session-start"
            ],
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/claude/memdir-hook.mjs",
              "user-prompt-submit"
            ],
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/claude/memdir-hook.mjs",
              "stop"
            ],
            "timeout": 15
          }
        ]
      }
    ]
  }
}
