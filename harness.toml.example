[memdir]
enabled = true
base_dir = "${HOME}/.project-memdir/memories/projects"
manifest_name = "manifest.json"
topics_dir_name = "topics"
max_entrypoint_lines = 200
max_entrypoint_bytes = 25000
manifest_recent_items = 20
max_relevant_memories = 3
recent_fallback_items = 0
min_relevant_score = 6

# cwd: stores memory by the exact directory where the hook or CLI session starts.
#      This is the default on POSIX and Windows, so subdirectories can have
#      separate memory projects even when a parent contains Git or project files.
# detect: walks upward from the session directory and uses project markers or Git
#         to keep nested sessions grouped under the detected project root.
[memdir.project_root]
strategy = "cwd"

# plugin: stores memories under a stable user data directory:
#   ${HOME}/.project-memdir/memories/projects/<project-slug>
#   <project-slug> preserves the UTF-8/Unicode project directory name in NFC form,
#   folds unsupported characters to "-", and appends a path digest.
# project: stores memories inside the active project:
#   <project-root>/.project-memdir
[memdir.storage]
mode = "plugin"
project_dir_name = ".project-memdir"

[memdir.vector]
index_name = "vector_index.sqlite3"
index_backend = "sqlite"
dimensions = 96
score_weight = 12
min_similarity = 0.2

# Leave credentials unset to use the built-in local hash embedding fallback.
#
# To use Cloudflare Workers AI embeddings, set environment variables instead of
# committing secrets:
#   export CLOUDFLARE_ACCOUNT_ID="..."
#   export CLOUDFLARE_API_TOKEN="..."
# Or configure local values in your user config copy only when that file is private:
#   CLOUDFLARE_ACCOUNT_ID = "..."
#   CLOUDFLARE_API_TOKEN = "..."
[memdir.embedding]
model = "@cf/google/embeddinggemma-300m"
dimensions = 768
timeout_sec = 15
failure_backoff_sec = 300
query_cache_ttl_sec = 86400
query_cache_max_entries = 256

# Supported values:
# - "agy": uses `agy -p ...` and can select a model with `agy_model`.
# - "codex": uses `codex exec` to write topic JSON files.
# - "local_cli": sends the extraction prompt to a local command through stdin or `{prompt}`.
#   For local CLI, only configure an agent or command that can create topic JSON result files.
# Choose one provider before relying on automatic Stop hook extraction.
# Keep "codex-default-model" or "" to use the Codex CLI default model.
# Keep "agy-default-model" or "" to use the agy CLI default model.
# The bundled example extractor is deterministic and safe to run by default.
# If a file-writing agent requires the prompt as an argument instead of stdin,
# include `{prompt}` in that agent command.
[memdir.extractor]
provider = ""

timeout_sec = 90
codex_bin = "codex"
codex_model = ""

agy_bin = "agy"
agy_extraction_timeout_sec = 90
agy_model = "agy-default-model"

local_cli_command = 'python "${CODEX_ROOT}/examples/local_extractor.py"'
local_cli_extraction_timeout_sec = 30
